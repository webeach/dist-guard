{
  "name": "@webeach/dist-guard",
  "version": "0.2.0",
  "description": "Blazing fast CLI to scan your compiled code (dist) for leaked tokens, API keys, and other secrets before deploying.",
  "keywords": [
    "api-keys",
    "cli",
    "dist",
    "scanner",
    "secrets",
    "security",
    "tokens",
    "trufflehog"
  ],
  "homepage": "https://github.com/webeach/dist-guard",
  "bugs": {
    "url": "https://github.com/webeach/dist-guard/issues"
  },
  "license": "MIT",
  "author": {
    "name": "Ruslan Martynov",
    "email": "github@webea.ch"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/webeach/dist-guard"
  },
  "bin": {
    "dist-guard": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "dist/index.cjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "release": "semantic-release",
    "prepare": "is-ci || husky"
  },
  "dependencies": {
    "@vscode/ripgrep": "^1.15.9",
    "cac": "^6.7.14"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.8",
    "@semantic-release/npm": "^13.1.5",
    "@semantic-release/release-notes-generator": "^14.1.1",
    "@types/node": "^25.9.1",
    "husky": "^9.1.7",
    "is-ci": "^4.1.0",
    "lint-staged": "^17.0.5",
    "oxfmt": "^0.51.0",
    "oxlint": "^1.66.0",
    "semantic-release": "^25.0.3",
    "tsup": "^8",
    "typescript": "^5.9.3",
    "vitest": "^4.1.7"
  },
  "lint-staged": {
    "**/*.{cjs,cts,js,jsx,mjs,mts,ts,tsx}": [
      "oxlint --fix",
      "oxfmt"
    ],
    "**/*.{md,mdc,mdx,json,jsonc}": [
      "oxfmt"
    ]
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": "^10"
  },
  "packageManager": "pnpm@10.7.1"
}
